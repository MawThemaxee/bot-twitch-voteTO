# Copy this file to .env and fill in your Twitch credentials
# DO NOT commit .env to version control

# Twitch Channel (without #)
TWITCH_CHANNEL=your_channel_name

# Twitch Bot Username
TWITCH_BOT_USERNAME=your_bot_username

# OAuth Token (get from npm run setup or use Twitch Token Generator)
# Format: oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_OAUTH_TOKEN=oauth:your_token_here

# Helix API Configuration
# Le bot récupérera automatiquement les IDs broadcaster et moderator
# au démarrage si CLIENT_ID est configuré. Sinon, vous pouvez les 
# configurer manuellement ici.
# Get CLIENT_ID from: https://console.cloud.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id_here

# (Optionnel) Configurer manuellement les IDs - si vides, seront auto-récupérés
TWITCH_BROADCASTER_ID=
TWITCH_MODERATOR_ID=

# Configuration du serveur web pour l'overlay
WEB_SERVER_ENABLED=false
WEB_SERVER_PORT=3000
WEB_SERVER_HOST=0.0.0.0

# Ban Configuration
BAN_DURATION_MINUTES=5
BAN_REASON=Vote pour interdiction
VOTE_THRESHOLD=3
VOTE_DURATION_SECONDS=60

# Optional: Debug Mode
DEBUG=false
