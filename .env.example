# Copy this file to .env and fill in your Twitch credentials
# DO NOT commit .env to version control

# Twitch Channel (without #)
TWITCH_CHANNEL=your_channel_name

# Twitch Bot Username
TWITCH_BOT_USERNAME=your_bot_username

# OAuth Token (get from https://twitchapps.com/tmi/)
# Format: oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_OAUTH_TOKEN=oauth:your_token_here

# Ban Configuration
BAN_DURATION_MINUTES=5
VOTE_THRESHOLD=3
VOTE_DURATION_SECONDS=60

# Optional: Debug Mode
DEBUG=false
